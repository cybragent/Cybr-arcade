  function burst(x,y,c){for(let i=0;i<8;i++)parts.push({x,y,vx:(Math.random()-.5)*4,vy:(Math.random()-1.5)*3,life:24+Math.random()*12,c});}
  function capColor(t){return t==='grow'?'#43d9ad':t==='multi'?'#ffd166':t==='slow'?'#4ea8ff':'#ff6b6b';}
  function capLabel(t){return t==='grow'?'↔':t==='multi'?'+':t==='slow'?'≈':'♥';}
