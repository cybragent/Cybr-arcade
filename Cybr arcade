      if(matched===pairs)ov.show('Solved! 🧠','In '+moves+' moves · '+Math.round((Date.now()-t0)/1000)+'s');}
    else{lock=true;const a=first;first=null;a.el.classList.add('bad');c.el.classList.add('bad');
      setTimeout(()=>{a.up=c.up=false;a.el.classList.remove('up','bad');c.el.classList.remove('up','bad');lock=false;},680);}}
