        if(br.hp<=0){br.a=false;score+=10;setHUD();burst(br.x+br.w/2,br.y+br.h/2,br.c);if(Math.random()<C.power)caps.push({x:br.x+br.w/2,y:br.y+br.h/2,type:['grow','multi','slow','life'][(Math.random()*4)|0]});}
