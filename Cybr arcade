/* =========================================================
   2048
========================================================= */
function mount2048(root,diff){
  const C={easy:{size:5,four:0.1},medium:{size:4,four:0.1},hard:{size:4,four:0.35}}[diff];
  const SIZE=C.size;
  const wrap=elc('div','gwrap');
  const sb=scoreBar('Score <b id="nS">0</b> · Best <b id="nB">'+getBest('2048-'+SIZE,diff)+'</b>',SIZE+'×'+SIZE+' · Arrows · WASD · swipe');
  const board=elc('div','g2048');board.style.gridTemplateColumns='repeat('+SIZE+',1fr)';board.style.gridTemplateRows='repeat('+SIZE+',1fr)';
  const fs=SIZE>=5?'clamp(15px,4.6vw,24px)':'clamp(18px,6vw,30px)';
  const ov=overlay();
  wrap.append(sb.bar,board,ov.box);root.appendChild(wrap);
  const COLORS={2:'#efe5d3',4:'#ecd9b0',8:'#ff8a3c',16:'#ff7a2e',32:'#ff6b6b',64:'#ff5151',128:'#ffd166',256:'#ffce4a',512:'#ffc62e',1024:'#43d9ad',2048:'#4ea8ff',4096:'#c792ff'};
  let g,score,won,lastNew;
  function reset(){g=Array.from({length:SIZE},()=>new Array(SIZE).fill(0));score=0;won=false;lastNew=null;document.getElementById('nS').textContent='0';ov.hide();add();add();draw();}
  function add(){const e=[];g.forEach((r,y)=>r.forEach((v,x)=>{if(!v)e.push([y,x]);}));if(!e.length)return;const[y,x]=e[(Math.random()*e.length)|0];g[y][x]=Math.random()<C.four?4:2;lastNew=y+','+x;}
  function draw(){board.innerHTML='';for(let y=0;y<SIZE;y++)for(let x=0;x<SIZE;x++){const v=g[y][x];const c=elc('div','cell'+(v&&lastNew===y+','+x?' new':''));c.style.fontSize=v>=1024?'clamp(13px,4vw,22px)':fs;if(v){c.textContent=v;c.style.background=COLORS[v]||'#3c2bbf';c.style.color=v>4?'#fff':'#1a140c';}board.appendChild(c);}}
  function slide(arr){let a=arr.filter(v=>v),r=[];for(let i=0;i<a.length;i++){if(a[i]===a[i+1]){r.push(a[i]*2);score+=a[i]*2;if(a[i]*2>=2048&&!won)won=true;i++;}else r.push(a[i]);}while(r.length<SIZE)r.push(0);return r;}
  function move(dir){const before=JSON.stringify(g);lastNew=null;
    if(dir==='l')g=g.map(slide);
    else if(dir==='r')g=g.map(r=>slide(r.slice().reverse()).reverse());
    else if(dir==='u'){for(let x=0;x<SIZE;x++){const col=[];for(let y=0;y<SIZE;y++)col.push(g[y][x]);const s=slide(col);for(let y=0;y<SIZE;y++)g[y][x]=s[y];}}
    else if(dir==='d'){for(let x=0;x<SIZE;x++){const col=[];for(let y=SIZE-1;y>=0;y--)col.push(g[y][x]);const s=slide(col);for(let y=0;y<SIZE;y++)g[SIZE-1-y][x]=s[y];}}
    if(JSON.stringify(g)!==before){add();document.getElementById('nS').textContent=score;document.getElementById('nB').textContent=setBest('2048-'+SIZE,diff,score);draw();
      if(won){won=false;ov.show('2048! 🎉','Keep going','Continue');}else if(lose())ov.show('Game Over','Score '+score);}}
  function lose(){for(let y=0;y<SIZE;y++)for(let x=0;x<SIZE;x++){if(!g[y][x])return false;if(x<SIZE-1&&g[y][x]===g[y][x+1])return false;if(y<SIZE-1&&g[y][x]===g[y+1][x])return false;}return true;}
  const oK=on(window,'keydown',e=>{const k=e.key.toLowerCase();let d=null;if(k==='arrowleft'||k==='a')d='l';else if(k==='arrowright'||k==='d')d='r';else if(k==='arrowup'||k==='w')d='u';else if(k==='arrowdown'||k==='s')d='d';if(d){e.preventDefault();move(d);}});
  let sx=null,sy=null;
  const oTS=on(board,'touchstart',e=>{const t=e.touches[0];sx=t.clientX;sy=t.clientY;},{passive:true});
  const oTE=on(board,'touchend',e=>{if(sx==null)return;const t=e.changedTouches[0],dx=t.clientX-sx,dy=t.clientY-sy;if(Math.max(Math.abs(dx),Math.abs(dy))<24){sx=sy=null;return;}if(Math.abs(dx)>Math.abs(dy))move(dx>0?'r':'l');else move(dy>0?'d':'u');sx=sy=null;},{passive:true});
  const oOv=on(ov.box,'click',()=>{ov.hide();if(lose())reset();});
  reset();
  return ()=>{oK();oTS();oTE();oOv();};
}

