    for(const br of bricks){if(!br.a)continue;ctx.fillStyle=br.hp>1?'#9aa0a8':br.c;rr(ctx,br.x,br.y,br.w,br.h,3);ctx.fill();ctx.fillStyle='rgba(255,255,255,.18)';rr(ctx,br.x,br.y,br.w,4,2);ctx.fill();}
