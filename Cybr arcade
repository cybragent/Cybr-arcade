  const ctx=cv.getContext('2d');
  const COLR=['#ff6b6b','#ff8a3c','#ffd166','#43d9ad','#4ea8ff','#c792ff'];
  let basePw=C.pw,pw,px,balls,bricks,caps,parts,score,lives,raf,running,speedMul,slowF,growF,leftK,rightK;
  function setHUD(){document.getElementById('bS').textContent=score;document.getElementById('bV').textContent=lives;}
  function mkBall(vx){return {x:W/2,y:H-48,vx:vx!=null?vx:(Math.random()<.5?-1:1)*C.bs*0.6,vy:-C.bs,r:7};}
  function reset(){pw=basePw;px=(W-pw)/2;score=0;lives=C.lives;running=true;speedMul=1;slowF=0;growF=0;leftK=rightK=false;caps=[];parts=[];
    setHUD();ov.hide();build();balls=[mkBall()];loop();}
  function build(){bricks=[];const cols=10,bw=(W-16)/cols,bh=15;
    for(let r=0;r<C.rows;r++)for(let c=0;c<cols;c++){let hp=1;if(C.steel&&((r*cols+c)%C.steel===0)&&r<C.rows-1)hp=2;bricks.push({x:8+c*bw,y:30+r*(bh+5),w:bw-5,h:bh,c:COLR[r%COLR.length],hp,a:true});}}
  function loop(){if(!running)return;update();render();raf=requestAnimationFrame(loop);}
  function update(){
    if(leftK)px-=7;if(rightK)px+=7;px=Math.max(0,Math.min(W-pw,px));
    if(growF>0){growF--;if(growF===0){const cx=px+pw/2;pw=basePw;px=Math.max(0,Math.min(W-pw,cx-pw/2));}}
    if(slowF>0)slowF--;
