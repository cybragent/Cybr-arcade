  function setPaddle(clientX){const r=cv.getBoundingClientRect();px=(clientX-r.left)*(W/r.width)-pw/2;px=Math.max(0,Math.min(W-pw,px));}
  function over(t,s){ov.show(t,s);}
  const oM=on(cv,'mousemove',e=>setPaddle(e.clientX));
  const oT=on(cv,'touchmove',e=>{setPaddle(e.touches[0].clientX);},{passive:true});
  const oK=on(window,'keydown',e=>{const k=e.key.toLowerCase();if(k==='arrowleft'||k==='a'){leftK=true;e.preventDefault();}if(k==='arrowright'||k==='d'){rightK=true;e.preventDefault();}if(k===' '&&!running)reset();});
  const oKU=on(window,'keyup',e=>{const k=e.key.toLowerCase();if(k==='arrowleft'||k==='a')leftK=false;if(k==='arrowright'||k==='d')rightK=false;});
  const oOv=on(ov.box,'click',()=>{if(!running)reset();});
