  function reset(){board=Array.from({length:ROWS},()=>new Array(COLS).fill(0));score=0;lines=0;level=1;dead=false;speed=C.speed;bag=null;
    document.getElementById('tS').textContent='0';document.getElementById('tL').textContent='0';document.getElementById('tLv').textContent='1';ov.hide();
    nextKey=fromBag();spawn();clearInterval(timer);timer=setInterval(step,speed);draw();}
  function gameover(){clearInterval(timer);dead=true;ov.show('Game Over','Score '+score);}
  const offK=on(window,'keydown',e=>{const k=e.key.toLowerCase();
    if(['arrowup','arrowdown','arrowleft','arrowright',' '].includes(e.key.toLowerCase())||['w','a','s','d'].includes(k))e.preventDefault();
    if(k==='arrowleft'||k==='a')move(-1);else if(k==='arrowright'||k==='d')move(1);else if(k==='arrowup'||k==='w')rotate();else if(k==='arrowdown'||k==='s')soft();else if(k===' ')dead?reset():hard();});
