<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>CYBR ARCADE</title>
<style>
  :root{
    --bg:#15110c; --panel:#221c15; --panel-2:#2a2319;
    --line:rgba(255,228,190,.12); --line-strong:rgba(255,228,190,.28);
    --text:#f3ead9; --muted:#ab9b86; --accent:#ffb454; --accent2:#ff8a3c;
    --font:'Trebuchet MS',Verdana,system-ui,-apple-system,'Segoe UI',Roboto,sans-serif;
  }
  *{box-sizing:border-box}
  html{-webkit-text-size-adjust:100%}
  body{margin:0;font-family:var(--font);color:var(--text);min-height:100vh;overflow-x:hidden;
    background:radial-gradient(1200px 600px at 50% -10%,#2a2014 0%,rgba(42,32,20,0) 60%),radial-gradient(900px 700px at 100% 0%,#20180f 0%,rgba(32,24,15,0) 55%),var(--bg);}
  .fx{position:fixed;inset:0;pointer-events:none;z-index:9999}
  .fx::before{content:"";position:absolute;inset:0;background:repeating-linear-gradient(to bottom,rgba(0,0,0,0) 0,rgba(0,0,0,0) 2px,rgba(0,0,0,.16) 3px,rgba(0,0,0,0) 4px);opacity:.32;mix-blend-mode:multiply}
  .fx::after{content:"";position:absolute;inset:0;box-shadow:inset 0 0 200px 40px rgba(0,0,0,.55)}

  header{padding:30px 18px 20px;text-align:center}
  .bulbs{display:flex;justify-content:center;gap:clamp(7px,2.4vw,16px);overflow:hidden;height:11px;margin:0 auto;max-width:760px}
  .bulb{width:9px;height:9px;border-radius:50%;flex:0 0 auto;background:var(--accent);box-shadow:0 0 7px var(--accent),0 0 14px var(--accent2);animation:bulb 1.25s ease-in-out infinite}
  @keyframes bulb{0%,100%{opacity:.22;transform:scale(.82)}50%{opacity:1;transform:scale(1)}}
  .logo{font-size:clamp(38px,8.5vw,78px);font-weight:900;line-height:1;margin:16px 0 4px;letter-spacing:3px;color:#ffe9c7;
    text-shadow:0 0 14px rgba(255,180,84,.6),0 0 34px rgba(255,138,60,.4),0 5px 0 #7a4a14,0 6px 14px rgba(0,0,0,.55);}
  .logo span{color:var(--accent)} .logo .slash{color:var(--accent2)}
  .tagline{margin:8px 0 16px;color:var(--muted);font-size:clamp(11px,2.4vw,14px);letter-spacing:.18em;text-transform:uppercase}
  .tagline b{color:var(--accent)}

  .toolbar{position:sticky;top:0;z-index:50;padding:12px 16px 10px;background:linear-gradient(180deg,rgba(21,17,12,.96),rgba(21,17,12,.82));backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
  .controls{display:flex;gap:10px;max-width:1100px;margin:0 auto;align-items:center}
  .search-wrap{position:relative;flex:1 1 auto;min-width:0}
  .search-wrap .ic{position:absolute;left:14px;top:50%;transform:translateY(-50%);font-size:15px;opacity:.7;pointer-events:none}
  #search{width:100%;padding:13px 40px;background:var(--panel);border:1px solid var(--line);border-radius:13px;color:var(--text);font-family:inherit;font-size:15px;outline:none;transition:border-color .18s,box-shadow .18s,background .18s}
  #search::placeholder{color:var(--muted)}
  #search:focus{border-color:var(--accent);background:var(--panel-2);box-shadow:0 0 0 3px rgba(255,180,84,.16)}
  #clear{position:absolute;right:8px;top:50%;transform:translateY(-50%);border:0;background:transparent;color:var(--muted);font-size:20px;cursor:pointer;line-height:1;padding:6px 8px;border-radius:8px;opacity:0;pointer-events:none;transition:opacity .15s}
  #clear.show{opacity:1;pointer-events:auto}#clear:hover{color:var(--text)}
  .chips{display:flex;gap:8px;max-width:1100px;margin:11px auto 0;overflow-x:auto;padding-bottom:3px;scrollbar-width:none}
  .chips::-webkit-scrollbar{display:none}
  .chip{flex:0 0 auto;display:inline-flex;align-items:center;gap:7px;padding:9px 15px;border-radius:999px;cursor:pointer;background:transparent;border:1px solid var(--line-strong);color:var(--muted);font-family:inherit;font-size:13.5px;font-weight:700;white-space:nowrap;transition:all .16s}
  .chip:hover{color:var(--text);border-color:var(--c)}
  .chip.active{color:#1a140c;background:var(--c);border-color:var(--c);box-shadow:0 0 14px -2px var(--c)}
  .chip .ct{font-size:11px;opacity:.65}

  .meta{max-width:1100px;margin:16px auto 4px;padding:0 18px;color:var(--muted);font-size:13px;display:flex;align-items:center;gap:8px}
  .meta .dot{width:5px;height:5px;border-radius:50%;background:var(--accent);box-shadow:0 0 8px var(--accent)}

  .grid{display:grid;gap:16px;max-width:1100px;margin:14px auto 40px;padding:0 18px 30px;grid-template-columns:repeat(auto-fill,minmax(min(100%,210px),1fr))}
  .card{position:relative;display:flex;flex-direction:column;background:var(--panel);border:1px solid var(--line);border-radius:16px;overflow:hidden;cursor:pointer;transition:transform .2s cubic-bezier(.2,.7,.3,1),box-shadow .2s,border-color .2s;animation:rise .36s cubic-bezier(.2,.7,.3,1) both;animation-delay:var(--delay,0ms)}
  .grid.no-anim .card{animation:none}
  @keyframes rise{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  .card:hover,.card:focus-visible{transform:translateY(-6px);border-color:var(--c);box-shadow:0 14px 30px -12px rgba(0,0,0,.7),0 0 22px -6px var(--c);outline:none}
  .thumb{position:relative;aspect-ratio:16/10;display:flex;align-items:center;justify-content:center;overflow:hidden;background:linear-gradient(140deg,color-mix(in srgb,var(--c) 48%,#241d14),#15100a)}
  .thumb .ico{font-size:62px;filter:drop-shadow(0 4px 10px rgba(0,0,0,.5));transition:transform .3s}
  .card:hover .thumb .ico{transform:scale(1.12) rotate(-4deg)}
  .thumb .glowline{position:absolute;inset:0;background:radial-gradient(circle at 50% 120%,color-mix(in srgb,var(--c) 40%,transparent),transparent 60%)}
  .play{position:absolute;right:9px;bottom:9px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:rgba(20,15,9,.6);border:2px solid var(--c);border-radius:50%;color:#fff;font-size:15px;padding-left:3px;opacity:0;transform:scale(.7);transition:opacity .2s,transform .2s;box-shadow:0 0 16px -3px var(--c)}
  .card:hover .play{opacity:1;transform:scale(1)}
  .tag{position:absolute;top:9px;left:9px;font-size:10.5px;font-weight:800;letter-spacing:.05em;text-transform:uppercase;padding:4px 9px;border-radius:999px;color:#1a140c;background:var(--c)}
  .star{position:absolute;top:7px;right:7px;width:30px;height:30px;border-radius:50%;border:0;cursor:pointer;background:rgba(20,15,9,.5);color:#f3ead9cc;font-size:15px;display:flex;align-items:center;justify-content:center;transition:transform .15s,color .15s}
  .star:hover{transform:scale(1.18)}.star.on{color:#ffd166;text-shadow:0 0 9px rgba(255,209,102,.85)}
  .card-body{padding:12px 13px 14px;display:flex;flex-direction:column;gap:3px}
  .title{font-size:16px;font-weight:700}
  .desc{font-size:12px;color:var(--muted);line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

  .empty{max-width:600px;margin:40px auto 80px;text-align:center;padding:0 24px;display:none}
  .empty.show{display:block}
  .empty .em{font-size:46px;margin-bottom:10px}.empty h3{font-size:20px;margin:0 0 8px}.empty p{color:var(--muted);margin:0;font-size:14px}

  footer{border-top:1px solid var(--line);max-width:1100px;margin:0 auto;padding:22px 18px 40px;color:var(--muted);font-size:12.5px;line-height:1.6;text-align:center}
  footer .note{opacity:.85;max-width:640px;margin:0 auto}

  /* Player modal */
  .player{position:fixed;inset:0;z-index:200;display:none;align-items:center;justify-content:center;padding:14px}
  .player.open{display:flex;animation:fade .2s ease both}
  @keyframes fade{from{opacity:0}to{opacity:1}}
  .backdrop{position:absolute;inset:0;background:rgba(8,6,3,.85);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
  .panel{position:relative;z-index:1;width:min(720px,100%);height:min(92vh,960px);display:flex;flex-direction:column;background:var(--panel);border:1px solid var(--line-strong);border-radius:18px;overflow:hidden;box-shadow:0 30px 80px -20px rgba(0,0,0,.8),0 0 44px -12px var(--c,#ffb454);animation:pop .26s cubic-bezier(.2,.8,.3,1) both}
  @keyframes pop{from{opacity:0;transform:translateY(14px) scale(.985)}to{opacity:1;transform:none}}
  .pbar{display:flex;align-items:center;gap:10px;padding:11px 12px 11px 16px;border-bottom:1px solid var(--line);background:linear-gradient(180deg,var(--panel-2),var(--panel))}
  .ptag{font-size:10.5px;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#1a140c;background:var(--c,#ffb454);padding:4px 9px;border-radius:999px;flex:0 0 auto}
  .ptitle{font-weight:800;font-size:16px;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .pbtn{flex:0 0 auto;display:inline-flex;align-items:center;gap:6px;border:1px solid var(--line-strong);background:transparent;color:var(--text);font-family:inherit;font-size:13px;font-weight:700;padding:8px 12px;border-radius:10px;cursor:pointer;transition:all .15s}
  .pbtn:hover{border-color:var(--accent);color:var(--accent)}
  .pbtn.close:hover{border-color:#ff6b6b;color:#ff6b6b}
  .pstage{position:relative;flex:1;min-height:0;overflow:auto;padding:16px}

  /* Difficulty bar */
  .diffbar{display:flex;align-items:center;gap:12px;justify-content:center;margin:0 auto 16px;flex-wrap:wrap}
  .difflabel{color:var(--muted);font-size:11.5px;letter-spacing:.14em;text-transform:uppercase}
  .diffseg{display:inline-flex;background:var(--panel-2);border:1px solid var(--line);border-radius:13px;padding:4px;gap:4px}
  .diffseg button{border:0;background:transparent;color:var(--muted);font-family:inherit;font-weight:800;font-size:13px;padding:9px 18px;border-radius:10px;cursor:pointer;transition:all .15s}
  .diffseg button:hover{color:var(--text)}
  .diffseg button.on{background:var(--c);color:#1a140c;box-shadow:0 0 12px -3px var(--c)}
  .gamehost{width:100%;display:flex;justify-content:center}

  /* In-game shared UI */
  .gwrap{position:relative;display:flex;flex-direction:column;gap:12px;align-items:center;width:100%}
  .gscore{display:flex;justify-content:space-between;align-items:center;gap:12px;width:100%;max-width:520px;font-size:14px;color:var(--text);flex-wrap:wrap}
  .gscore b{color:var(--accent);font-size:17px}
  .ghint{color:var(--muted);font-size:11.5px;letter-spacing:.03em}
  .gcanvas{display:block;width:100%;height:auto;margin:0 auto;background:#0c0907;border-radius:12px;border:1px solid var(--line);touch-action:none}
  .gnext{display:flex;align-items:center;gap:8px;color:var(--muted);font-size:12px}
  .gnext canvas{background:#0c0907;border:1px solid var(--line);border-radius:8px}
  .gover{position:absolute;inset:0;display:none;flex-direction:column;align-items:center;justify-content:center;gap:10px;background:rgba(10,7,4,.78);backdrop-filter:blur(3px);border-radius:12px;text-align:center;cursor:pointer;z-index:5}
  .gover.show{display:flex;animation:fade .2s ease both}
  .gover-t{font-size:26px;font-weight:900;letter-spacing:1px;color:#ffe9c7;text-shadow:0 0 16px rgba(255,180,84,.5)}
  .gover-s{font-size:14px;color:var(--muted)}
  .gover-b{margin-top:6px;border:1px solid var(--accent);background:rgba(255,180,84,.12);color:var(--accent);font-family:inherit;font-weight:800;font-size:14px;padding:10px 22px;border-radius:11px;cursor:pointer;letter-spacing:.04em}
  .gpad{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;width:100%;max-width:360px}
  .gbtn{flex:1 1 auto;min-width:54px;border:1px solid var(--line-strong);background:var(--panel-2);color:var(--text);font-family:inherit;font-size:20px;font-weight:700;padding:12px 0;border-radius:12px;cursor:pointer;user-select:none;-webkit-user-select:none;touch-action:manipulation;transition:background .12s,transform .05s}
  .gbtn:active{background:var(--accent);color:#1a140c;transform:scale(.96)}

  /* 2048 */
  .g2048{width:100%;max-width:380px;aspect-ratio:1;background:#2a2319;border-radius:12px;padding:8px;display:grid;gap:8px;touch-action:none}
  .g2048 .cell{background:rgba(255,255,255,.04);border-radius:8px;display:flex;align-items:center;justify-content:center;font-weight:800;color:#1a140c}
  .g2048 .cell.new{animation:pop2048 .16s ease}
  @keyframes pop2048{from{transform:scale(.5)}to{transform:scale(1)}}

  .gboard{display:grid;gap:8px;width:100%;max-width:380px;touch-action:manipulation}

  /* Memory 3D cards */
  .mcard{aspect-ratio:1;background:transparent;border:0;cursor:pointer;padding:0;perspective:600px}
  .mcard .inner{position:relative;width:100%;height:100%;transform-style:preserve-3d;transition:transform .35s cubic-bezier(.2,.7,.3,1)}
  .mcard.up .inner,.mcard.matched .inner{transform:rotateY(180deg)}
  .mface{position:absolute;inset:0;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:10px;display:flex;align-items:center;justify-content:center}
  .mback{background:linear-gradient(135deg,#3a2f20,#241d14);border:1px solid var(--line);color:var(--accent);font-size:22px}
  .mfront{transform:rotateY(180deg);background:#3a2f20;border:1px solid var(--line-strong);font-size:clamp(20px,7vw,34px)}
  .mcard.matched .mfront{background:rgba(67,217,173,.16);border-color:rgba(67,217,173,.45)}
  .mcard.bad .inner{animation:mshake .35s}
  @keyframes mshake{0%,100%{transform:rotateY(180deg)}30%{transform:rotateY(180deg) translateX(-7px)}70%{transform:rotateY(180deg) translateX(7px)}}

  /* Whack */
  .hole{position:relative;aspect-ratio:1;border-radius:50% 50% 46% 46%;background:radial-gradient(ellipse at 50% 30%,#2a2319 0%,#15100a 70%);border:1px solid var(--line);display:flex;align-items:flex-end;justify-content:center;overflow:hidden;cursor:pointer;user-select:none}
  .hole::after{content:"";position:absolute;bottom:0;left:8%;right:8%;height:26%;background:radial-gradient(ellipse at 50% 100%,#0a0705,transparent 70%)}
  .hole .mole{font-size:clamp(28px,9vw,40px);transform:translateY(120%);transition:transform .11s ease;line-height:1}
  .hole.up .mole{transform:translateY(14%)}
  .float{position:absolute;left:50%;top:24%;transform:translateX(-50%);font-weight:900;font-size:20px;pointer-events:none;animation:floatUp .7s ease forwards;z-index:2}
  .float.plus{color:#ffd166}.float.minus{color:#ff6b6b}
  @keyframes floatUp{from{opacity:1;transform:translate(-50%,0)}to{opacity:0;transform:translate(-50%,-32px)}}

  /* Minesweeper */
  .mine{aspect-ratio:1;border:1px solid var(--line);border-radius:5px;background:var(--panel-2);font-weight:800;font-size:inherit;display:flex;align-items:center;justify-content:center;cursor:pointer;user-select:none;color:var(--text)}
  .mine.rev{background:#1a150f;cursor:default}.mine.flag{color:#ffd166}.mine.boom{background:#5a1e1e}

  /* Tic tac toe */
  .ttt{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;width:100%;max-width:320px;aspect-ratio:1}
  .ttt .sq{border:1px solid var(--line-strong);border-radius:12px;background:var(--panel-2);font-size:clamp(34px,12vw,56px);font-weight:900;display:flex;align-items:center;justify-content:center;cursor:pointer;user-select:none;transition:box-shadow .2s,background .2s}
  .ttt .sq.x{color:#4ea8ff}.ttt .sq.o{color:#ff6b6b}
  .ttt .sq.win{box-shadow:0 0 18px -1px var(--accent);background:rgba(255,180,84,.16)}

  @media (max-width:560px){
    .grid{grid-template-columns:repeat(auto-fill,minmax(min(100%,150px),1fr));gap:12px;padding:0 12px 30px}
    .thumb .ico{font-size:48px}
    .player{padding:0}.panel{width:100%;height:100%;border-radius:0;border:0}
    .ptag{display:none}.pstage{padding:12px}
    .diffseg button{padding:9px 13px}
  }
  @media (prefers-reduced-motion:reduce){.card,.bulb,.gover,.player,.mcard .inner{animation:none!important;transition:none!important}}
</style>
</head>
<body>
<div class="fx"></div>

<header>
  <div class="bulbs" id="bulbsTop"></div>
  <h1 class="logo">CYBR<span class="slash">//</span><span>ARCADE</span></h1>
  <p class="tagline" id="tagline">loading cabinets…</p>
  <div class="bulbs" id="bulbsBot"></div>
</header>

<div class="toolbar">
  <div class="controls">
    <div class="search-wrap">
      <span class="ic">🔍</span>
      <input id="search" type="text" placeholder="Search games…" autocomplete="off" spellcheck="false" aria-label="Search games">
      <button id="clear" aria-label="Clear search">×</button>
    </div>
  </div>
  <div class="chips" id="chips"></div>
</div>

<div class="meta"><span class="dot"></span><span id="count"></span></div>
<main class="grid" id="grid"></main>

<div class="empty" id="empty"><div class="em">🕹️</div><h3>No games here</h3><p id="emptyMsg">Try a different search or category.</p></div>

<footer><p class="note">Every game is built into this single file and runs entirely in your browser — no servers, no links, no internet needed, works fully offline. Pick a difficulty up top, then play with arrow keys / WASD, or tap / swipe on touch.</p></footer>

<div class="player" id="player" aria-hidden="true">
  <div class="backdrop" data-close></div>
  <div class="panel" id="panel" role="dialog" aria-modal="true" aria-label="Game player">
    <div class="pbar">
      <span class="ptag" id="pTag"></span>
      <span class="ptitle" id="pTitle"></span>
      <button class="pbtn" id="pRestart" type="button" title="Restart">↺<span class="lbl"> Restart</span></button>
      <button class="pbtn close" id="pClose" type="button" data-close title="Close (Esc)">✕</button>
    </div>
    <div class="pstage" id="pStage"></div>
  </div>
</div>

<script>
"use strict";
/* ---------- helpers ---------- */
function on(t,e,fn,o){t.addEventListener(e,fn,o);return ()=>t.removeEventListener(e,fn,o);}
function elc(tag,cls,txt){const n=document.createElement(tag);if(cls)n.className=cls;if(txt!=null)n.textContent=txt;return n;}
const esc=s=>String(s).replace(/[&<>"]/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;"}[c]));
function rr(ctx,x,y,w,h,r){r=Math.min(r,w/2,h/2);ctx.beginPath();ctx.moveTo(x+r,y);ctx.arcTo(x+w,y,x+w,y+h,r);ctx.arcTo(x+w,y+h,x,y+h,r);ctx.arcTo(x,y+h,x,y,r);ctx.arcTo(x,y,x+w,y,r);ctx.closePath();}
const BEST={};
function getBest(id,d){return BEST[id+':'+d]||0;}
function setBest(id,d,v){const k=id+':'+d;if(v>(BEST[k]||0))BEST[k]=v;return BEST[k];}

function overlay(){
  const box=elc('div','gover');
  const t=elc('div','gover-t'),s=elc('div','gover-s'),b=elc('button','gover-b','Play again');
  box.append(t,s,b);
  return {box,show(title,sub,btn){t.textContent=title;s.textContent=sub||'';b.textContent=btn||'Play again';box.classList.add('show');},hide(){box.classList.remove('show');}};
}
function scoreBar(html,hint){const bar=elc('div','gscore');const l=elc('div',null);l.innerHTML=html;const h=elc('div','ghint',hint||'');bar.append(l,h);return {bar,l,h};}

/* =========================================================
   SNAKE
========================================================= */
function mountSnake(root,diff){
  const C={easy:{speed:150,wrap:true,ramp:0},medium:{speed:105,wrap:false,ramp:0},hard:{speed:82,wrap:false,ramp:6}}[diff];
  const N=20,CELL=18,W=N*CELL;
  const wrap=elc('div','gwrap');
  const sb=scoreBar('Score <b id="snS">0</b> · Best <b id="snB">'+getBest('snake',diff)+'</b>',(C.wrap?'Walls wrap · ':'')+'Arrows · WASD · swipe');
  const cv=elc('canvas','gcanvas');cv.width=W;cv.height=W;cv.style.maxWidth='380px';
  const ov=overlay();
  wrap.append(sb.bar,cv,ov.box);root.appendChild(wrap);
  const ctx=cv.getContext('2d');
  let snake,dir,nd,food,score,timer,dead,speed;
  function reset(){snake=[{x:9,y:10},{x:8,y:10},{x:7,y:10}];dir={x:1,y:0};nd=dir;score=0;dead=false;speed=C.speed;
    document.getElementById('snS').textContent='0';food=newFood();ov.hide();clearInterval(timer);timer=setInterval(tick,speed);draw();}
  function newFood(){let f;do{f={x:(Math.random()*N)|0,y:(Math.random()*N)|0};}while(snake.some(s=>s.x===f.x&&s.y===f.y));return f;}
  function tick(){dir=nd;let hx=snake[0].x+dir.x,hy=snake[0].y+dir.y;
    if(C.wrap){hx=(hx+N)%N;hy=(hy+N)%N;}
    if(hx<0||hy<0||hx>=N||hy>=N||snake.some(s=>s.x===hx&&s.y===hy)){over();return;}
    const h={x:hx,y:hy};snake.unshift(h);
    if(h.x===food.x&&h.y===food.y){score++;document.getElementById('snS').textContent=score;food=newFood();
      if(C.ramp&&score%5===0){speed=Math.max(55,speed-C.ramp);clearInterval(timer);timer=setInterval(tick,speed);}}
    else snake.pop();
    draw();}
  function draw(){ctx.fillStyle='#0c0907';ctx.fillRect(0,0,W,W);
