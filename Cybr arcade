  function blk(c2,x,y,col,alpha){if(y<0)return;c2.globalAlpha=alpha||1;c2.fillStyle=col;c2.fillRect(x*B+1,y*B+1,B-2,B-2);c2.fillStyle='rgba(255,255,255,.16)';c2.fillRect(x*B+1,y*B+1,B-2,4);c2.fillStyle='rgba(0,0,0,.18)';c2.fillRect(x*B+1,y*B+B-5,B-2,4);c2.globalAlpha=1;}
