      if(b.y+b.r>=H-22&&b.y<H-8&&b.x>px-2&&b.x<px+pw+2&&b.vy>0){const hp=(b.x-(px+pw/2))/(pw/2);const s=C.bs;b.vx=Math.max(-1.1,Math.min(1.1,hp))*s*1.15;b.vy=-Math.sqrt(Math.max(s*s-b.vx*b.vx,(s*0.45)*(s*0.45)));}
