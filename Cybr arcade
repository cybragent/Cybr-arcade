  return `<div class="card" data-id="${g.id}" tabindex="0" role="button" aria-label="Play ${esc(g.title)}" style="--c:${col};--delay:${d}ms">
    <div class="thumb"><div class="glowline"></div><div class="ico">${g.icon}</div><span class="tag">${esc(g.cat)}</span>
      <button type="button" class="star${fav?' on':''}" data-fav="${g.id}" aria-label="Toggle favorite">${fav?'★':'☆'}</button><span class="play">▶</span></div>
    <div class="card-body"><div class="title">${esc(g.title)}</div><div class="desc">${esc(g.desc)}</div></div></div>`;}
function render(animate){const list=filtered();gridEl.classList.toggle('no-anim',!animate);gridEl.innerHTML=list.map(cardHTML).join('');
  countEl.textContent=(query.trim()||activeCat!=='All')?`Showing ${list.length} of ${GAMES.length} games`:`${GAMES.length} games · 3 difficulties each · all offline`;
  if(list.length===0){emptyEl.classList.add('show');emptyMsg.textContent=activeCat==='Favorites'?'No favorites yet — tap the ☆ on a game.':'No games match that search.';}else emptyEl.classList.remove('show');}

/* ----- player ----- */
const player=$('#player'),panel=$('#panel'),stage=$('#pStage'),pTitle=$('#pTitle'),pTag=$('#pTag');
let lastFocus=null,curGame=null,cleanup=null,gameHost=null;
function buildDiff(){const bar=elc('div','diffbar');bar.appendChild(elc('span','difflabel','Difficulty'));const seg=elc('div','diffseg');
  DIFFS.forEach(o=>{const b=elc('button',null,o.label);b.dataset.d=o.d;b.style.setProperty('--c',o.c);if(o.d===difficulty)b.classList.add('on');
    on(b,'click',()=>{if(difficulty===o.d)return;difficulty=o.d;seg.querySelectorAll('button').forEach(x=>x.classList.toggle('on',x.dataset.d===o.d));mountCur();});seg.appendChild(b);});
  bar.appendChild(seg);return bar;}
function mountCur(){if(cleanup){try{cleanup();}catch(e){}}cleanup=null;gameHost.innerHTML='';try{cleanup=curGame.mount(gameHost,difficulty)||null;}catch(err){console.error(err);gameHost.innerHTML='<div style="color:#ab9b86;padding:20px">Could not start this game.</div>';}}
function openPlayer(g){lastFocus=document.activeElement;curGame=g;pTitle.textContent=g.title;pTag.textContent=g.cat;const col=catColor(g.cat);pTag.style.background=col;panel.style.setProperty('--c',col);
  stage.innerHTML='';stage.appendChild(buildDiff());gameHost=elc('div','gamehost');stage.appendChild(gameHost);
  mountCur();player.classList.add('open');player.setAttribute('aria-hidden','false');document.body.style.overflow='hidden';$('#pClose').focus();}
function restart(){mountCur();}
function closePlayer(){if(cleanup){try{cleanup();}catch(e){}}cleanup=null;stage.innerHTML='';player.classList.remove('open');player.setAttribute('aria-hidden','true');document.body.style.overflow='';if(lastFocus&&lastFocus.focus)lastFocus.focus();}
$('#pRestart').addEventListener('click',restart);
player.addEventListener('click',e=>{if(e.target.closest('[data-close]'))closePlayer();});
document.addEventListener('keydown',e=>{if(e.key==='Escape'&&player.classList.contains('open'))closePlayer();});

/* ----- hub interactions ----- */
gridEl.addEventListener('click',e=>{const star=e.target.closest('.star');
  if(star){e.stopPropagation();const id=star.dataset.fav;favorites.has(id)?favorites.delete(id):favorites.add(id);buildChips();render(false);return;}
  const card=e.target.closest('.card');if(card)openPlayer(GAMES.find(g=>g.id===card.dataset.id));});
gridEl.addEventListener('keydown',e=>{if(e.key!=='Enter'&&e.key!==' ')return;const card=e.target.closest('.card');if(card){e.preventDefault();openPlayer(GAMES.find(g=>g.id===card.dataset.id));}});
chipsEl.addEventListener('click',e=>{const chip=e.target.closest('.chip');if(!chip)return;activeCat=chip.dataset.cat;buildChips();render(true);});
searchEl.addEventListener('input',e=>{query=e.target.value;clearEl.classList.toggle('show',query.length>0);render(false);});
clearEl.addEventListener('click',()=>{query='';searchEl.value='';clearEl.classList.remove('show');searchEl.focus();render(false);});

/* ----- marquee bulbs ----- */
function buildBulbs(){const n=Math.max(8,Math.min(34,Math.floor(Math.min(window.innerWidth,760)/26)));
  [$('#bulbsTop'),$('#bulbsBot')].forEach(el=>{el.innerHTML='';for(let i=0;i<n;i++){const b=elc('span','bulb');b.style.animationDelay=(i*0.08)+'s';el.appendChild(b);}});}
let rt;window.addEventListener('resize',()=>{clearTimeout(rt);rt=setTimeout(buildBulbs,200);});

/* ----- init ----- */
$('#tagline').innerHTML=`<b>${GAMES.length}</b> games · easy / medium / hard · no internet needed`;
buildBulbs();buildChips();render(true);
</script>
</body>
</html>
