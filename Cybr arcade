/* =========================================================
   MINESWEEPER
========================================================= */
function mountMines(root,diff){
  const C={easy:{n:9,m:10},medium:{n:12,m:24},hard:{n:16,m:45}}[diff];
  const N=C.n,M=C.m;
  const wrap=elc('div','gwrap');
  const sb=scoreBar('Mines <b id="kM">'+M+'</b> · Time <b id="kT">0</b>s','Tap reveal · long-press/right-click flag · tap number to chord');
  const board=elc('div','gboard');board.style.gridTemplateColumns='repeat('+N+',1fr)';board.style.maxWidth=(N>=16?'440px':N>=12?'400px':'340px');
  board.style.fontSize=(N<=9?16:N<=12?13:11)+'px';board.style.gap=(N>=16?'4px':'6px');
  const ov=overlay();
  wrap.append(sb.bar,board,ov.box);root.appendChild(wrap);
  const NUMC=['','#4ea8ff','#43d9ad','#ff6b6b','#c792ff','#ff8a3c','#56cfe1','#ffd166','#f3ead9'];
  let st,placed,over,flags,revealed,handlers,timer,secs,started;
  function idx(r,c){return r*N+c;}
  function reset(){handlers&&handlers.forEach(h=>h());handlers=[];clearInterval(timer);
    st=Array.from({length:N*N},()=>({m:false,r:false,f:false,n:0}));placed=false;over=false;flags=0;revealed=0;secs=0;started=false;
    document.getElementById('kM').textContent=M;document.getElementById('kT').textContent='0';ov.hide();board.innerHTML='';
    for(let i=0;i<N*N;i++){const b=elc('button','mine');
      handlers.push(on(b,'click',()=>tap(i)));
      handlers.push(on(b,'contextmenu',e=>{e.preventDefault();flag(i);}));
      let lp=null;
      handlers.push(on(b,'touchstart',()=>{lp=setTimeout(()=>{flag(i);lp=null;},420);},{passive:true}));
      handlers.push(on(b,'touchend',e=>{if(lp){clearTimeout(lp);lp=null;}else e.preventDefault();},{passive:false}));
      st[i].el=b;board.appendChild(b);}
    paint();}
  function startClock(){if(started)return;started=true;timer=setInterval(()=>{secs++;document.getElementById('kT').textContent=secs;},1000);}
  function neigh(i){const r=(i/N)|0,c=i%N,o=[];for(let dr=-1;dr<=1;dr++)for(let dc=-1;dc<=1;dc++){if(!dr&&!dc)continue;const nr=r+dr,nc=c+dc;if(nr>=0&&nr<N&&nc>=0&&nc<N)o.push(idx(nr,nc));}return o;}
  function place(safe){const ban=new Set([safe,...neigh(safe)]);let put=0;while(put<M){const i=(Math.random()*N*N)|0;if(st[i].m||ban.has(i))continue;st[i].m=true;put++;}
    st.forEach((c,i)=>{if(!c.m)c.n=neigh(i).filter(j=>st[j].m).length;});placed=true;}
  function tap(i){if(over)return;const c=st[i];
    if(c.r&&c.n>0){const fl=neigh(i).filter(j=>st[j].f).length;if(fl===c.n)neigh(i).forEach(j=>{if(!st[j].f)reveal(j);});paint();win();return;}
    reveal(i);paint();win();}
  function reveal(i){if(over||st[i].f||st[i].r)return;if(!placed)place(i);startClock();const c=st[i];c.r=true;revealed++;
    if(c.m){c.el.classList.add('boom');c.el.textContent='💥';lose();return;}if(c.n===0)neigh(i).forEach(reveal);}
  function flag(i){if(over||st[i].r)return;startClock();st[i].f=!st[i].f;flags+=st[i].f?1:-1;document.getElementById('kM').textContent=M-flags;paint();}
  function paint(){st.forEach(c=>{const b=c.el;b.className='mine';b.textContent='';b.style.color='';
    if(c.r){b.classList.add('rev');if(c.m){b.textContent='💣';}else if(c.n){b.textContent=c.n;b.style.color=NUMC[c.n];}}else if(c.f){b.classList.add('flag');b.textContent='🚩';}});}
  function lose(){over=true;clearInterval(timer);st.forEach(c=>{if(c.m&&!c.r){c.el.classList.add('rev');c.el.textContent='💣';}});ov.show('Boom 💥','Try again');}
  function win(){if(!over&&revealed===N*N-M){over=true;clearInterval(timer);ov.show('Cleared! 🚩','Time: '+secs+'s');}}
  const oOv=on(ov.box,'click',()=>reset());
  reset();
  return ()=>{clearInterval(timer);handlers&&handlers.forEach(h=>h());oOv();};
}

/* =========================================================
   TIC-TAC-TOE
========================================================= */
function mountTTT(root,diff){
  const MODE={easy:'random',medium:'smart',hard:'perfect'}[diff];
  const wrap=elc('div','gwrap');
  const sb=scoreBar('You <b id="wW">0</b> · AI <b id="wA">0</b> · Draw <b id="wD">0</b>','You are X · '+(MODE==='perfect'?'AI is unbeatable':MODE==='smart'?'AI plays smart':'AI plays casual'));
  const grid=elc('div','ttt');
  const ov=overlay();
  wrap.append(sb.bar,grid,ov.box);root.appendChild(wrap);
  const LINES=[[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
  let bd,locked,handlers,wins={W:0,A:0,D:0};
  function winLine(b){for(const L of LINES){const[a,c,d]=L;if(b[a]&&b[a]===b[c]&&b[a]===b[d])return L;}return null;}
  function winner(b){const L=winLine(b);return L?b[L[0]]:null;}
  function empties(b){const e=[];b.forEach((v,i)=>{if(!v)e.push(i);});return e;}
  function minimax(b,p){const w=winner(b);if(w==='O')return{s:1};if(w==='X')return{s:-1};if(b.every(v=>v))return{s:0};
    let mv=null;for(const i of empties(b)){const nb=b.slice();nb[i]=p;const r=minimax(nb,p==='O'?'X':'O');if(!mv||(p==='O'?r.s>mv.s:r.s<mv.s))mv={s:r.s,i};}return mv;}
  function findLine(b,p){for(const[a,c,d]of LINES){const line=[b[a],b[c],b[d]];if(line.filter(v=>v===p).length===2&&line.includes(''))return [a,c,d][line.indexOf('')];}return -1;}
  function aiMove(){const e=empties(bd);if(!e.length)return -1;
    if(MODE==='random')return e[(Math.random()*e.length)|0];
    if(MODE==='perfect')return minimax(bd,'O').i;
    // smart: win, block, center, corner, edge, with a little noise
    let i=findLine(bd,'O');if(i>=0)return i;
    if(Math.random()>0.12){i=findLine(bd,'X');if(i>=0)return i;}
    if(!bd[4])return 4;
    const corners=[0,2,6,8].filter(c=>!bd[c]);if(corners.length)return corners[(Math.random()*corners.length)|0];
    return e[(Math.random()*e.length)|0];}
  function reset(){handlers&&handlers.forEach(h=>h());handlers=[];bd=new Array(9).fill('');locked=false;ov.hide();grid.innerHTML='';
    for(let i=0;i<9;i++){const sq=elc('button','sq');handlers.push(on(sq,'click',()=>play(i)));grid.appendChild(sq);}}
  function paint(){bd.forEach((v,i)=>{const sq=grid.children[i];sq.textContent=v;sq.className='sq'+(v==='X'?' x':v==='O'?' o':'');});}
  function play(i){if(locked||bd[i])return;bd[i]='X';paint();if(end())return;locked=true;
    setTimeout(()=>{const m=aiMove();if(m>=0)bd[m]='O';paint();locked=false;end();},240);}
  function end(){const L=winLine(bd),w=L?bd[L[0]]:null;
    if(w==='X'){L.forEach(i=>grid.children[i].classList.add('win'));wins.W++;document.getElementById('wW').textContent=wins.W;ov.show('You win! 🎉','Nice one');return true;}
    if(w==='O'){L.forEach(i=>grid.children[i].classList.add('win'));wins.A++;document.getElementById('wA').textContent=wins.A;ov.show('AI wins 🤖','Rematch?');return true;}
    if(bd.every(v=>v)){wins.D++;document.getElementById('wD').textContent=wins.D;ov.show('Draw 🤝','Go again');return true;}
    return false;}
  const oOv=on(ov.box,'click',()=>reset());
  reset();
  return ()=>{handlers&&handlers.forEach(h=>h());oOv();};
}

/* =========================================================
   WHACK-A-MOLE
========================================================= */
function mountWhack(root,diff){
  const C={easy:{up:1100,iv:[800,1200],max:1,time:45,bomb:0},medium:{up:760,iv:[620,980],max:2,time:30,bomb:.18},hard:{up:480,iv:[430,720],max:3,time:30,bomb:.28}}[diff];
  const wrap=elc('div','gwrap');
  const sb=scoreBar('Score <b id="hS">0</b> · Time <b id="hT">'+C.time+'</b>s · Best <b id="hB">'+getBest('whack',diff)+'</b>','Whack moles 🐹 · avoid bombs 💣');
  const board=elc('div','gboard');board.style.gridTemplateColumns='repeat(3,1fr)';board.style.maxWidth='320px';
  const ov=overlay();
  wrap.append(sb.bar,board,ov.box);root.appendChild(wrap);
  let holes,score,time,popT,duckT,clockT,running;
  function build(){board.innerHTML='';holes=[];for(let i=0;i<9;i++){const h=elc('div','hole');const m=elc('div','mole','🐹');h.appendChild(m);on(h,'click',()=>whack(i));board.appendChild(h);holes.push({el:h,mole:m,up:false,type:'mole'});}}
  function ready(){build();score=0;time=C.time;running=false;document.getElementById('hS').textContent='0';document.getElementById('hT').textContent=C.time;ov.show('Whack-a-Mole','Tap Start to begin','Start');}
  function begin(){running=true;score=0;time=C.time;document.getElementById('hS').textContent='0';document.getElementById('hT').textContent=C.time;ov.hide();
    clearInterval(clockT);clearTimeout(popT);clearTimeout(duckT);
    clockT=setInterval(()=>{time--;document.getElementById('hT').textContent=time;if(time<=0)end();},1000);pop();}
  function down(h){h.up=false;h.el.classList.remove('up');}
  function pop(){if(!running)return;holes.forEach(down);
    const n=1+((Math.random()*C.max)|0);const used=new Set();
    for(let k=0;k<n;k++){let i;do{i=(Math.random()*9)|0;}while(used.has(i));used.add(i);const h=holes[i];h.type=(Math.random()<C.bomb)?'bomb':'mole';h.mole.textContent=h.type==='bomb'?'💣':'🐹';h.up=true;h.el.classList.add('up');}
    duckT=setTimeout(()=>{used.forEach(i=>down(holes[i]));},C.up);
    popT=setTimeout(pop,C.iv[0]+Math.random()*(C.iv[1]-C.iv[0]));}
  function float(h,txt,cls){const f=elc('div','float '+cls,txt);h.el.appendChild(f);setTimeout(()=>f.remove(),700);}
  function whack(i){if(!running)return;const h=holes[i];if(!h.up)return;
    if(h.type==='bomb'){score=Math.max(0,score-2);float(h,'-2','minus');h.mole.textContent='💥';}
    else{score++;float(h,'+1','plus');h.mole.textContent='😵';}
    document.getElementById('hS').textContent=score;down(h);setTimeout(()=>{h.mole.textContent=h.type==='bomb'?'💣':'🐹';},180);}
  function end(){running=false;clearInterval(clockT);clearTimeout(popT);clearTimeout(duckT);holes.forEach(down);const b=setBest('whack',diff,score);document.getElementById('hB').textContent=b;ov.show('Time! ⏱️','You scored '+score,'Play again');}
  const oOv=on(ov.box,'click',()=>{running?ready():begin();});
  ready();
  return ()=>{running=false;clearInterval(clockT);clearTimeout(popT);clearTimeout(duckT);oOv();};
}

